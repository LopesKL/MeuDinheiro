<?xml version="1.0" encoding="utf-8"?>
<!-- IIS / 500.30: a app precisa de PostgreSQL.
     Opção A — Variável de ambiente do site: ConnectionStrings__PostgreSQL = (string Npgsql completa)
     Opção B — Ficheiro na pasta da app: postgres-connection.txt (uma linha, mesma string; não commite)
     Pasta logs\ deve existir (dotnet publish cria). Erros: logs\startup-failure.txt e logs\stdout_*.log -->
<configuration>
  <location path="." inheritInChildApplications="false">
    <system.webServer>
      <handlers>
        <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
      </handlers>
      <aspNetCore processPath="dotnet"
                  arguments=".\WebAPI.dll"
                  stdoutLogEnabled="true"
                  stdoutLogFile=".\logs\stdout"
                  hostingModel="inprocess">
        <environmentVariables>
          <environmentVariable name="ASPNETCORE_ENVIRONMENT" value="Production" />
        </environmentVariables>
      </aspNetCore>
    </system.webServer>
  </location>
</configuration>
