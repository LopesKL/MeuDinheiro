# Deixe vazio: o navegador chama http://localhost:3000/api/... e o Vite repassa para a API (vite.config.js).
VITE_API_URL=https://localhost:44363/

# Se preferir chamar a API direto no axios (sem proxy), use HTTPS na porta do IIS Express:
# VITE_API_URL=https://localhost:44363

VITE_USE_MOCK_AUTH=false

# Opcional: outro host/porta da API no proxy (variável lida pelo Node ao subir o Vite)
# VITE_PROXY_API_TARGET=https://localhost:5001
